# OpenSkill-Forge: Containerized Security Scanner & Skill Workshop
# Part of the OpenTrApp perimeter — handles untrusted SKILL files
# inside the container, never on the host.
#
# Build:  podman build -t vault-skills -f Containerfile .
# Or:     docker build -t vault-skills -f Containerfile .
#
# Run:    podman run --rm vault-skills make scan SKILL=api-dev
#         podman run --rm vault-skills make verify SKILL=api-dev

# WS-B: alpine base (python:3.10-alpine, ~40 MB vs python:3.10-slim ~126 MB).
# The scripts are stdlib-only Python (json/sys/re/subprocess/urllib) over a
# bash + GNU-coreutils toolchain; apk's grep/sed/gawk/findutils are the GNU
# versions (not busybox), so scanner/parser behaviour is unchanged. Verified by
# `make self-test` + `make scan` on this base.
FROM python:3.10-alpine@sha256:cb0f3c7df8d980aed5c2a84cc6b83cdcd3ef5a359a2ff68ec750946e86fe281a

LABEL maintainer="OpenSkill-Forge" \
      description="Skill security scanner — scans, verifies, and rebuilds untrusted SKILL files inside the perimeter"

# bash-first toolchain: GNU grep/sed/gawk/findutils for scanner/parser text
# processing, curl for ClawHub downloads, git for `make new`, make as the entry
# point. No external Python packages — all scripts use stdlib only
# (json, sys, re, subprocess, urllib.request).
RUN apk --no-cache add bash curl git make grep sed gawk findutils ca-certificates

# Non-root user — forge doesn't need root for anything.
RUN addgroup -g 1000 forge \
    && adduser -u 1000 -G forge -D -h /home/forge -s /bin/bash forge

WORKDIR /app

# Copy project files
COPY --chown=forge:forge . /app

# Ensure scripts are executable
RUN chmod +x tools/*.sh tools/lib/*.sh 2>/dev/null; \
    chmod +x tools/lib/*.py 2>/dev/null; \
    true

# Create directories for runtime data
# quarantine/: CDR pipeline downloads untrusted files here (never leaves container)
# exports/: certified skills ready for delivery to agent workspace
RUN mkdir -p quarantine exports \
    && chown -R forge:forge quarantine exports

# Run as non-root
USER forge

# Default: interactive bash (compose overrides with specific commands)
CMD ["bash"]
