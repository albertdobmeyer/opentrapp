# OpenAgent-Social: Containerized Feed Scanner & Monitoring Station
# Part of the OpenTrApp perimeter — processes untrusted Moltbook
# content inside the container, never on the host.
#
# Build:  podman build -t vault-social -f Containerfile .
# Or:     docker build -t vault-social -f Containerfile .
#
# Run:    podman run --rm vault-social make scan
#         podman run --rm vault-social make census

# WS-B: alpine base (python:3.10-alpine, ~40 MB vs python:3.10-slim ~126 MB).
# The tools are bash + GNU-coreutils + jq over stdlib Python; apk's grep/sed are
# the GNU versions (not busybox), so pattern-matching behaviour is unchanged.
# PyYAML installs from the musllinux wheel (no compiler needed). Verified by
# `make test` + a feed scan on this base.
FROM python:3.10-alpine@sha256:cb0f3c7df8d980aed5c2a84cc6b83cdcd3ef5a359a2ff68ec750946e86fe281a

LABEL maintainer="OpenAgent-Social" \
      description="Feed injection scanner — filters untrusted social content inside the perimeter"

# System deps: curl (Moltbook API fetch), jq (JSON formatting), grep/sed (GNU,
# pattern matching), make (entry point), bash, ca-certificates.
RUN apk --no-cache add bash curl jq make grep sed ca-certificates

# PyYAML is the only external Python dependency — used by export-patterns.py.
# pip resolves the musllinux binary wheel on alpine, so no build toolchain is needed.
RUN pip install --no-cache-dir PyYAML

# Non-root user — social doesn't need root for anything.
RUN addgroup -g 1000 social \
    && adduser -u 1000 -G social -D -h /home/social -s /bin/bash social

WORKDIR /app

# Copy project files
COPY --chown=social:social . /app

# Ensure scripts are executable
RUN chmod +x tools/*.sh scripts/*.sh 2>/dev/null; \
    chmod +x scripts/*.py 2>/dev/null; \
    true

# Create data directory for census snapshots and scan results
RUN mkdir -p data \
    && chown -R social:social data

# Copy .env template if no .env exists (setup step)
RUN cp -n config/.env.example config/.env 2>/dev/null; true

# Run as non-root
USER social

# Default: interactive bash (compose overrides with specific commands)
CMD ["bash"]
