# vault-proxy — the goproxy-based L7 egress chokepoint (ADR-0026), replacing the
# leaky Python mitmproxy (~250 MB image, 54 MB -> 550 MB RSS leak). Multi-stage:
# build a static, stripped binary, ship it on a minimal pinned alpine.
# Target: ~10-15 MB image, <50 MB RSS, leak-free.
FROM golang:1.25.11-alpine@sha256:523c3effe300580ed375e43f43b1c9b091b68e935a7c3a92bfcc4e7ed55b18c2 AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# Static (CGO off), trimmed + stripped. Pure-Go DNS (the rebinding resolver) is fine.
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /vault-proxy .

# Pinned alpine (same digest as infra/egress) — the shipped runtime image.
FROM alpine:3.21@sha256:48b0309ca019d89d40f670aa1bc06e426dc0931948452e8491e3d65087abc07d
RUN apk --no-cache add ca-certificates tini su-exec \
    && addgroup -g 1000 -S mitmproxy \
    && adduser -u 1000 -S mitmproxy -G mitmproxy -h /home/mitmproxy \
    && mkdir -p /home/mitmproxy/.mitmproxy /var/log/vault-proxy /opt/vault \
    && chown -R mitmproxy:mitmproxy /home/mitmproxy /var/log/vault-proxy
COPY --from=builder /vault-proxy /usr/local/bin/vault-proxy
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh
EXPOSE 8080
# tini PID1 -> entrypoint (chown the mounted vols, drop to mitmproxy) -> vault-proxy.
ENTRYPOINT ["/sbin/tini", "--", "/usr/local/bin/entrypoint.sh"]
