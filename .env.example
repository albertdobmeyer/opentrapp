# OpenTrApp runtime environment
#
# Copy this file to .env and fill in your keys before running the perimeter:
#   cp .env.example .env
#   # edit .env — set ANTHROPIC_API_KEY and TELEGRAM_BOT_TOKEN
#   podman compose up -d
#
# Security notes:
#   - ANTHROPIC_API_KEY is proxy-injected by vault-proxy; it never enters
#     vault-agent directly (ADR-0001). Keep this file out of version control.
#   - TELEGRAM_BOT_TOKEN does enter vault-agent so OpenClaw can poll Telegram.
#   - This .env is read by podman compose from the repo root (where compose.yml
#     lives). Do not move it.

# Required: Anthropic API key (injected by vault-proxy, never seen by the agent)
ANTHROPIC_API_KEY=sk-ant-...

# Required: Telegram bot token (used by vault-agent to poll @opentrappbot)
TELEGRAM_BOT_TOKEN=...

# Optional: OpenAI-compatible key (leave blank if using Anthropic only)
OPENAI_API_KEY=
