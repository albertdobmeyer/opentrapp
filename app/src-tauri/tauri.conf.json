{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri-config-schema/main/schema.json",
  "productName": "OpenTrApp",
  "version": "0.7.1",
  "identifier": "dev.opentrapp.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://img.shields.io; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "externalBin": ["binaries/opentrapp-daemon"],
    "resources": {
      "resources/perimeter": "perimeter"
    },
    "shortDescription": "Security-first desktop GUI for the OpenClaw ecosystem",
    "copyright": "Copyright (c) 2026 Albert Dobmeyer",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.sectigo.com"
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      },
      "signingIdentity": null,
      "providerShortName": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libappindicator3-1"
        ],
        "section": "utils",
        "priority": "optional"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "store": null,
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/albertdobmeyer/opentrapp/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBOEVDNkM4QzFEOUYzMDcKUldRSDg5bkJ5TWFPS3NoazZPVkQwYUtDS0RMWjdIc2I2QVgxNXlJS1F6eThTcUJQeDVPTCtWS1EK"
    }
  }
}
