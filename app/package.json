{
  "name": "opentrapp",
  "private": true,
  "version": "0.9.0",
  "description": "Containerization perimeter + skill scanner for autonomous CLI agents",
  "author": "Albert Dobmeyer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/albertdobmeyer/opentrapp.git"
  },
  "homepage": "https://github.com/albertdobmeyer/opentrapp#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "demo:record": "bash ../scripts/demo-gif.sh",
    "demo:wizard": "bash ../scripts/demo-gif.sh demo-wizard.spec.ts",
    "demo:tour": "bash ../scripts/demo-gif.sh demo-tour.spec.ts",
    "lint": "eslint . --max-warnings 0",
    "test:coverage": "vitest run --coverage",
    "test:e2e:coverage": "rm -rf .nyc_output coverage-e2e && VITE_COVERAGE=true playwright test --project=default && nyc report --reporter=json --reporter=text-summary --report-dir=coverage-e2e",
    "coverage:combined": "npm run test:coverage && npm run test:e2e:coverage && node scripts/merge-coverage.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "js-yaml": "^4.2.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "overrides": {
    "ws": "^8.20.1",
    "brace-expansion@5": "^5.0.6",
    "js-yaml": "^4.2.0",
    "eslint-plugin-react": {
      "eslint": "$eslint"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.20",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-unicorn": "^69.0.0",
    "globals": "^17.6.0",
    "jsdom": "^25.0.0",
    "nyc": "^18.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.5"
  }
}
