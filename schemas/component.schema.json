{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://opentrapp.dev/schemas/component.schema.json",
  "title": "Component Manifest",
  "description": "Self-describing manifest for OpenTrApp components. Each sub-repo publishes a component.yml that the GUI discovers and renders generically.",
  "type": "object",
  "required": ["identity"],
  "additionalProperties": false,
  "properties": {
    "identity": {
      "type": "object",
      "description": "Who is this component?",
      "required": ["id", "name", "version", "description", "role"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "URL-safe slug identifier"
        },
        "name": {
          "type": "string",
          "description": "human-readable display name"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+",
          "description": "Semantic version"
        },
        "description": {
          "type": "string",
          "description": "One-line summary"
        },
        "role": {
          "type": "string",
          "enum": ["runtime", "toolchain", "network", "placeholder"],
          "description": "Component role in the ecosystem"
        },
        "icon": {
          "type": "string",
          "description": "Lucide icon name (e.g. 'shield', 'hammer')"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Hex accent color"
        },
        "repo": {
          "type": "string",
          "format": "uri",
          "description": "Git repository URL"
        }
      }
    },
    "status": {
      "type": "object",
      "description": "How to determine component state",
      "additionalProperties": false,
      "properties": {
        "states": {
          "type": "array",
          "description": "Declared possible states",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z_]+$"
              },
              "label": {
                "type": "string"
              },
              "icon": {
                "type": "string",
                "description": "Lucide icon name"
              },
              "color": {
                "type": "string",
                "pattern": "^#[0-9a-fA-F]{6}$"
              }
            }
          }
        },
        "probes": {
          "type": "array",
          "description": "Commands the GUI polls to determine current state",
          "items": {
            "type": "object",
            "required": ["command", "rules"],
            "additionalProperties": false,
            "properties": {
              "command": {
                "type": "string",
                "description": "Shell command to execute"
              },
              "interval_seconds": {
                "type": "integer",
                "minimum": 1,
                "default": 10
              },
              "timeout_seconds": {
                "type": "integer",
                "minimum": 1,
                "default": 5
              },
              "rules": {
                "type": "array",
                "description": "Match rules evaluated in order; first match wins",
                "items": {
                  "type": "object",
                  "required": ["state"],
                  "additionalProperties": false,
                  "properties": {
                    "exit_code": {
                      "type": "integer",
                      "description": "Match on process exit code"
                    },
                    "stdout_contains": {
                      "type": "string",
                      "description": "Match if stdout contains this string"
                    },
                    "stdout_regex": {
                      "type": "string",
                      "description": "Match if stdout matches this regex"
                    },
                    "state": {
                      "type": "string",
                      "description": "State ID to set when this rule matches"
                    }
                  }
                }
              }
            }
          }
        },
        "default_state": {
          "type": "string",
          "description": "Fallback state when no probe rule matches"
        }
      }
    },
    "commands": {
      "type": "array",
      "description": "Actions the user can perform",
      "items": {
        "type": "object",
        "required": ["id", "name", "command"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "group": {
            "type": "string",
            "enum": ["lifecycle", "operations", "monitoring", "maintenance"],
            "default": "operations"
          },
          "type": {
            "type": "string",
            "enum": ["action", "query", "stream"],
            "default": "action"
          },
          "danger": {
            "type": "string",
            "enum": ["safe", "caution", "destructive"],
            "default": "safe"
          },
          "boundary_impact": {
            "type": "string",
            "description": "ADR-0021 security axis (distinct from operational `danger`): does this op reduce the perimeter's protection? `neutral` operates within the cage; `weakening` reduces it (tears down the perimeter, loosens egress, weakens the shell). Defaults to `weakening` (fail-closed): an unclassified op is treated as boundary-weakening.",
            "enum": ["neutral", "weakening"],
            "default": "weakening"
          },
          "command": {
            "type": "string",
            "description": "Shell command with ${arg_id} interpolation"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "type"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9_]+$"
                },
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": ["string", "enum", "boolean", "number"]
                },
                "required": {
                  "type": "boolean",
                  "default": false
                },
                "default": {},
                "options": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Static options for enum type"
                },
                "options_from": {
                  "type": "object",
                  "description": "Dynamic options loaded from command output",
                  "additionalProperties": false,
                  "properties": {
                    "command": {
                      "type": "string",
                      "description": "Shell command that outputs one option per line"
                    },
                    "timeout_seconds": {
                      "type": "integer",
                      "default": 5
                    }
                  },
                  "required": ["command"]
                }
              }
            }
          },
          "output": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "format": {
                "type": "string",
                "enum": ["text", "ansi", "json", "jsonl", "sarif"],
                "default": "text"
              },
              "display": {
                "type": "string",
                "enum": ["log", "table", "badge", "checklist", "card-grid", "terminal", "report"],
                "default": "log"
              }
            }
          },
          "available_when": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "State IDs where this command is enabled. Empty = always available."
          },
          "sort_order": {
            "type": "integer",
            "default": 100
          },
          "tier": {
            "type": "string",
            "enum": ["user", "advanced"],
            "default": "advanced",
            "description": "UI tier: user-facing commands shown by default, advanced commands collapsed"
          },
          "timeout_seconds": {
            "type": "integer",
            "default": 60
          }
        }
      }
    },
    "configs": {
      "type": "array",
      "description": "Editable configuration files",
      "items": {
        "type": "object",
        "required": ["path", "format"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path from component root"
          },
          "name": {
            "type": "string",
            "description": "Display name"
          },
          "description": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "enum": ["yaml", "json", "json5", "env", "line-list"]
          },
          "editable": {
            "type": "boolean",
            "default": true
          },
          "danger": {
            "type": "string",
            "enum": ["safe", "caution", "destructive"],
            "default": "safe"
          },
          "schema": {
            "type": "object",
            "description": "JSON Schema for structured formats (drives form generation)"
          },
          "line_list": {
            "type": "object",
            "description": "Metadata for line-list format files",
            "additionalProperties": false,
            "properties": {
              "item_label": {
                "type": "string",
                "description": "What each line represents (e.g. 'domain')"
              },
              "pattern": {
                "type": "string",
                "description": "Regex validation for each line"
              },
              "example": {
                "type": "string",
                "description": "Example entry"
              }
            }
          },
          "restart_required": {
            "type": "boolean",
            "default": false
          },
          "restart_command": {
            "type": "string",
            "description": "Command ID to offer after saving (must reference a commands[].id)"
          }
        }
      }
    },
    "prerequisites": {
      "type": "object",
      "description": "What this component needs before it can run",
      "additionalProperties": false,
      "properties": {
        "container_runtime": {
          "type": "boolean",
          "description": "Whether this component requires Docker/Podman",
          "default": false
        },
        "setup_command": {
          "type": "string",
          "description": "Command ID from commands[] to run during setup"
        },
        "config_files": {
          "type": "array",
          "description": "Config files that must exist before the component works",
          "items": {
            "type": "object",
            "required": ["path"],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "description": "Relative path from component root"
              },
              "template": {
                "type": "string",
                "description": "Template file to copy from (relative path)"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "check_command": {
          "type": "string",
          "description": "Shell command — exit 0 means prerequisites are met"
        }
      }
    },
    "health": {
      "type": "array",
      "description": "Dashboard health badges — lightweight periodic probes for telemetry",
      "items": {
        "type": "object",
        "required": ["id", "name", "command", "parse"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "interval_seconds": {
            "type": "integer",
            "minimum": 5,
            "default": 30
          },
          "timeout_seconds": {
            "type": "integer",
            "default": 10
          },
          "parse": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["regex", "json_path", "line_count", "exit_code"]
              },
              "expression": {
                "type": "string",
                "description": "Regex capture group, JSON path, or unused for line_count/exit_code"
              },
              "format": {
                "type": "string",
                "description": "Display format string (e.g. '{value} skills')"
              }
            },
            "required": ["type"]
          },
          "thresholds": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "green": {
                "type": "string",
                "description": "Condition for green (e.g. '>= 1', '== 0')"
              },
              "yellow": {
                "type": "string",
                "description": "Condition for yellow"
              },
              "red": {
                "type": "string",
                "description": "Condition for red"
              }
            }
          }
        }
      }
    },
    "workflows": {
      "type": "array",
      "description": "Multi-step automated sequences. Each workflow chains declared commands into a single user-facing action that the GUI or an external agent (Claude Code) can trigger.",
      "items": {
        "type": "object",
        "required": ["id", "name", "steps"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "URL-safe workflow identifier"
          },
          "name": {
            "type": "string",
            "description": "human-readable display name"
          },
          "description": {
            "type": "string",
            "description": "Technical description for developers"
          },
          "user_description": {
            "type": "string",
            "description": "Plain-language explanation shown to non-technical users in the GUI"
          },
          "trigger": {
            "type": "string",
            "enum": ["manual", "on-demand", "automatic", "scheduled"],
            "default": "manual",
            "description": "When this workflow executes: manual (user clicks), on-demand (requested by another workflow), automatic (triggered by events), scheduled (periodic)"
          },
          "danger": {
            "type": "string",
            "enum": ["safe", "caution", "destructive"],
            "default": "safe"
          },
          "shell_requirement": {
            "type": "string",
            "enum": ["hard", "split", "soft", "any"],
            "default": "any",
            "description": "Minimum shell level required to run this workflow"
          },
          "steps": {
            "type": "array",
            "description": "Ordered sequence of steps. Each step references a declared command ID.",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "command"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$",
                  "description": "Step identifier (unique within this workflow)"
                },
                "command": {
                  "type": "string",
                  "description": "Command ID from this component's commands[] array"
                },
                "name": {
                  "type": "string",
                  "description": "Step display name (defaults to referenced command's name)"
                },
                "args": {
                  "type": "object",
                  "description": "Argument values for the command. Supports {{input.x}} for workflow inputs and {{steps.prev_id.output}} for previous step output.",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "depends_on": {
                  "type": "string",
                  "description": "Step ID that must complete before this step runs (default: previous step)"
                },
                "abort_on_failure": {
                  "type": "boolean",
                  "default": true,
                  "description": "If true, workflow aborts when this step fails"
                },
                "success_condition": {
                  "type": "object",
                  "description": "How to determine if this step succeeded (default: exit code 0)",
                  "additionalProperties": false,
                  "properties": {
                    "exit_code": {
                      "type": "integer"
                    },
                    "stdout_contains": {
                      "type": "string"
                    },
                    "stdout_regex": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "inputs": {
            "type": "array",
            "description": "User-provided inputs for this workflow (prompted before execution)",
            "items": {
              "type": "object",
              "required": ["id", "type", "label"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9_]+$"
                },
                "type": {
                  "type": "string",
                  "enum": ["string", "url", "enum", "boolean", "number"]
                },
                "label": {
                  "type": "string",
                  "description": "Display label"
                },
                "description": {
                  "type": "string"
                },
                "required": {
                  "type": "boolean",
                  "default": true
                },
                "default": {},
                "options": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Static options for enum type"
                }
              }
            }
          },
          "output": {
            "type": "object",
            "description": "What this workflow produces as its final result",
            "additionalProperties": false,
            "properties": {
              "display": {
                "type": "string",
                "enum": ["log", "checklist", "report", "badge"],
                "default": "checklist",
                "description": "How to render workflow results in the GUI"
              },
              "summary_step": {
                "type": "string",
                "description": "Step ID whose output is used as the workflow summary"
              }
            }
          }
        }
      }
    }
  }
}
